# .gitignore - Security First!

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variables - CRITICAL: Never commit these
.env
.env.local
.env.*.local
backend/.env
frontend/.env
frontend/.env.production
.env.production
.env.development

# Firebase & Credentials - CRITICAL: Never commit these
firebase-service-account.json
firebase-service-account*.json
*.serviceAccountKey.json
.firebaserc
.firebase/
.runtimeconfig.json

# Build outputs
dist/
build/
*.tsbuildinfo
frontend/build/
backend/dist/

# IDE and editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace
.env.local.php

# Testing
coverage/
.nyc_output/
.jest-cache/

# Logs
logs/
*.log
lerna-debug.log*

# OS files
Thumbs.db
.DS_Store
*.pem
*.key

# Credentials and secrets - CRITICAL
credentials.json
*.pem
*.key
private_key.json
service_account.json
.aws/
.gcloud/

# API Keys and Tokens
.env*.local
config/keys.json
secrets/
.secrets/

# Deploy files (optional - comment out if you want to track)
deploy.sh
deploy.bat
deploy-heroku.sh
deploy-complete.sh

# Package managers
package-lock.json
yarn.lock
pnpm-lock.yaml

# Misc
.turbo/
dist-ssr
*.local

service-account-key.json

# Docker
.dockerignore
Dockerfile

# Git
.git/
